---
import { maraudersImages } from '../data/marauders';
import { mainNav, siteConfig } from '../data/site';

const current = Astro.url.pathname;
const isActive = (href: string) =>
	href === '/' ? current === '/' : current === href || current.startsWith(href);
---

<header class="nav" data-nav>
	<div class="nav__bar">
		<a href="/" class="nav__brand" aria-label="Marauders Cheats Home">
			<img
				src={maraudersImages.logo}
				alt={siteConfig.name}
				width="40"
				height="40"
				class="nav__logo"
				decoding="async"
			/>
			<span class="nav__name">Marauders</span>
		</a>

		<nav class="nav__links" aria-label="Primary">
			{
				mainNav.map((link) => (
					<a href={link.href} class:list={['nav__link', { 'is-active': isActive(link.href) }]}>
						{link.label}
					</a>
				))
			}
		</nav>

		<div class="nav__end">
			<a href={siteConfig.checkoutUrl} class="nav__cta">Get Access</a>
			<button
				type="button"
				class="nav__toggle"
				aria-label="Open menu"
				aria-expanded="false"
				aria-controls="nav-panel"
				data-nav-toggle
			>
				<span class="nav__toggle-icon" aria-hidden="true"></span>
			</button>
		</div>
	</div>

	<div class="nav__panel" id="nav-panel" data-nav-panel hidden>
		<nav class="nav__panel-links" aria-label="Mobile">
			{
				mainNav.map((link) => (
					<a href={link.href} class:list={['nav__panel-link', { 'is-active': isActive(link.href) }]}>
						{link.label}
					</a>
				))
			}
			<a href={siteConfig.checkoutUrl} class="nav__panel-cta">Get Access</a>
		</nav>
	</div>
</header>

<script>
	const nav = document.querySelector('[data-nav]');
	if (nav) {
		const toggle = nav.querySelector('[data-nav-toggle]');
		const panel = nav.querySelector('[data-nav-panel]');

		const setOpen = (open: boolean) => {
			toggle?.setAttribute('aria-expanded', String(open));
			toggle?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
			if (panel instanceof HTMLElement) panel.hidden = !open;
			document.body.classList.toggle('nav-open', open);
		};

		toggle?.addEventListener('click', () => {
			setOpen(toggle.getAttribute('aria-expanded') !== 'true');
		});

		panel?.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => setOpen(false));
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && panel instanceof HTMLElement && !panel.hidden) {
				setOpen(false);
			}
		});

		const onScroll = () => nav.classList.toggle('is-scrolled', window.scrollY > 8);
		onScroll();
		window.addEventListener('scroll', onScroll, { passive: true });
	}
</script>

<style is:global>
	body.nav-open {
		overflow: hidden;
	}
</style>

<style>
	.nav {
		position: sticky;
		top: 0;
		z-index: 80;
		padding: 0.65rem var(--page-gutter) 0;
		padding-top: calc(0.65rem + env(safe-area-inset-top, 0px));
		pointer-events: none;
	}

	.nav__bar {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		width: min(100%, var(--page-max));
		margin: 0 auto;
		padding: 0.55rem 0.85rem;
		border-radius: 999px;
		border: 1px solid rgba(168, 85, 247, 0.12);
		background: rgba(10, 6, 18, 0.72);
		backdrop-filter: blur(16px) saturate(1.15);
		box-shadow: 0 4px 24px rgba(0, 0, 0, 0.18);
		pointer-events: auto;
		transition:
			background 0.25s ease,
			border-color 0.25s ease,
			box-shadow 0.25s ease;
	}

	.nav.is-scrolled .nav__bar {
		background: rgba(10, 6, 18, 0.94);
		border-color: rgba(168, 85, 247, 0.2);
		box-shadow: 0 8px 28px rgba(0, 0, 0, 0.32);
	}

	.nav__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		flex-shrink: 0;
		color: var(--color-ink);
		transition: opacity 0.2s ease;
	}

	.nav__brand:hover {
		opacity: 0.9;
	}

	.nav__logo {
		display: block;
		width: 2rem;
		height: 2rem;
		object-fit: contain;
	}

	.nav__name {
		font-family: var(--font-display);
		font-size: 0.95rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		white-space: nowrap;
	}

	.nav__links {
		display: flex;
		align-items: center;
		gap: 0.15rem;
		flex: 1;
		min-width: 0;
	}

	.nav__link {
		position: relative;
		padding: 0.45rem 0.7rem;
		border-radius: 0.5rem;
		color: var(--color-muted);
		font-size: 0.84rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		white-space: nowrap;
		transition: color 0.2s ease;
	}

	.nav__link::after {
		content: '';
		position: absolute;
		left: 0.7rem;
		right: 0.7rem;
		bottom: 0.3rem;
		height: 1px;
		border-radius: 1px;
		background: var(--color-orchid);
		transform: scaleX(0);
		transform-origin: center;
		transition: transform 0.2s ease;
	}

	.nav__link:hover {
		color: var(--color-ink);
	}

	.nav__link.is-active {
		color: var(--color-ink);
		font-weight: 600;
	}

	.nav__link.is-active::after {
		transform: scaleX(1);
	}

	.nav__end {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
		margin-left: auto;
	}

	.nav__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 2.15rem;
		padding: 0 1rem;
		border-radius: 999px;
		background: var(--color-ink);
		color: var(--color-midnight);
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.01em;
		transition:
			transform 0.2s ease,
			opacity 0.2s ease;
	}

	.nav__cta:hover {
		transform: translateY(-1px);
		opacity: 0.92;
		color: var(--color-midnight);
	}

	.nav__toggle {
		display: none;
		place-items: center;
		width: 2.15rem;
		height: 2.15rem;
		border: 0;
		border-radius: 999px;
		background: rgba(168, 85, 247, 0.12);
		color: var(--color-ink);
		cursor: pointer;
		transition: background 0.2s ease;
	}

	.nav__toggle:hover {
		background: rgba(168, 85, 247, 0.22);
	}

	.nav__toggle-icon,
	.nav__toggle-icon::before,
	.nav__toggle-icon::after {
		display: block;
		width: 16px;
		height: 2px;
		border-radius: 2px;
		background: currentColor;
		transition:
			transform 0.25s ease,
			opacity 0.2s ease;
	}

	.nav__toggle-icon {
		position: relative;
	}

	.nav__toggle-icon::before,
	.nav__toggle-icon::after {
		content: '';
		position: absolute;
		left: 0;
	}

	.nav__toggle-icon::before {
		top: -5px;
	}

	.nav__toggle-icon::after {
		top: 5px;
	}

	.nav__toggle[aria-expanded='true'] .nav__toggle-icon {
		background: transparent;
	}

	.nav__toggle[aria-expanded='true'] .nav__toggle-icon::before {
		top: 0;
		transform: rotate(45deg);
	}

	.nav__toggle[aria-expanded='true'] .nav__toggle-icon::after {
		top: 0;
		transform: rotate(-45deg);
	}

	.nav__panel {
		position: fixed;
		inset: 0;
		z-index: 79;
		display: grid;
		align-content: start;
		padding: calc(4.5rem + env(safe-area-inset-top, 0px)) var(--page-gutter) 2rem;
		background: rgba(10, 6, 18, 0.55);
		backdrop-filter: blur(6px);
		pointer-events: auto;
		animation: nav-fade 0.2s ease;
	}

	.nav__panel[hidden] {
		display: none;
	}

	.nav__panel-links {
		display: grid;
		gap: 0.35rem;
		width: min(100%, 22rem);
		margin: 0 auto;
		padding: 0.85rem;
		border-radius: 1rem;
		border: 1px solid rgba(168, 85, 247, 0.16);
		background: rgba(16, 12, 26, 0.96);
		box-shadow: 0 20px 48px rgba(0, 0, 0, 0.4);
	}

	.nav__panel-link {
		padding: 0.85rem 1rem;
		border-radius: 0.65rem;
		color: var(--color-muted);
		font-size: 1rem;
		font-weight: 500;
		transition:
			color 0.2s ease,
			background 0.2s ease;
	}

	.nav__panel-link:hover,
	.nav__panel-link.is-active {
		color: var(--color-ink);
		background: rgba(168, 85, 247, 0.1);
	}

	.nav__panel-cta {
		margin-top: 0.35rem;
		padding: 0.9rem 1rem;
		border-radius: 0.65rem;
		background: var(--color-ink);
		color: var(--color-midnight);
		font-size: 0.95rem;
		font-weight: 700;
		text-align: center;
	}

	@keyframes nav-fade {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	@media (max-width: 900px) {
		.nav__links {
			display: none;
		}

		.nav__cta {
			display: none;
		}

		.nav__toggle {
			display: grid;
		}
	}

	@media (max-width: 420px) {
		.nav__name {
			display: none;
		}
	}
</style>
